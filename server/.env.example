# ============================================
# SERVER ENVIRONMENT VARIABLES (example)
# ============================================
# Copy this file to .env and fill in real values. Never commit the real .env —
# it's already gitignored. See docs/ENVIRONMENT_VARIABLES.md for full details
# on every variable, including which ones are optional and what their defaults are.

# --- Server Config ---
PORT=8000
NODE_ENV=development

# --- Supabase Config (all required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=spreadsheet-uploads

# --- Supabase Postgres connection strings (required) ---
# DATABASE_URL: pooled connection (pgbouncer), used for the app's runtime queries.
# DIRECT_URL: direct connection, used by Prisma for migrations.
DATABASE_URL="postgresql://user:password@pooler-host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@direct-host:5432/postgres"

# --- Frontend URL for CORS (required in production) ---
CLIENT_URL=http://localhost:3000

# --- Google Sheets Config (optional — only needed for Google Sheets sync) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# --- Web Push (VAPID) Config (optional but recommended) ---
# Generate with `npx web-push generate-vapid-keys`. If left blank, the server
# generates ephemeral keys at startup, but push subscriptions won't survive a restart.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@yourdomain.com

# --- Health check (optional but recommended for production) ---
# Required in the `x-api-key` header to call GET /api/health as an external
# monitor. If left blank, one is generated at startup and logged (won't survive a restart).
HEALTH_CHECK_API_KEY=

# --- Defaults (optional) ---
# Fallback minimum OE% used when a worksheet/process has no explicit threshold configured.
DEFAULT_EFFICIENCY_THRESHOLD=85
