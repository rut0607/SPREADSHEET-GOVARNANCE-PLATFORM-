# ============================================
# CLIENT ENVIRONMENT VARIABLES (example)
# ============================================
# Copy this file to .env and fill in real values. React env vars are baked in
# at BUILD time (must be prefixed REACT_APP_) — set these before `npm run build`,
# not just on the server. See docs/ENVIRONMENT_VARIABLES.md for full details.

# Backend API base URL. Only trusted when the page is loaded from localhost —
# see client/src/services/api.js for why (LAN/phone testing derives the API
# host from the page's own hostname instead).
REACT_APP_API_URL=http://localhost:8000/api

# Port used when deriving the API URL from the page's own hostname (LAN testing,
# or whenever REACT_APP_API_URL above isn't trusted). Keep in sync with the
# server's PORT.
REACT_APP_API_PORT=8000

# Currently unused — no code in client/src imports @supabase/supabase-js or reads
# these. Present for possible future direct-Supabase-client use; safe to leave
# unset. See docs/ENVIRONMENT_VARIABLES.md for details.
# REACT_APP_SUPABASE_URL=
# REACT_APP_SUPABASE_ANON_KEY=
